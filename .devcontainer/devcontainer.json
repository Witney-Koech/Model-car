{
  "name": "ROS 2 Jazzy + Model-car",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "version": "latest",
      "noVncVersion": "1.4.0"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-iot.vscode-ros",
        "ms-python.python",
        "ms-python.pylint",
        "ms-vscode.cpptools",
        "redhat.vscode-xml",
        "twxs.cmake",
        "ms-vscode.cmake-tools",
        "GitHub.vscode-pull-request-github",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "ros.distro": "jazzy",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "postCreateCommand": "sudo rosdep update && rosdep install --from-paths src --ignore-src -r -y",

  "forwardPorts": [6080, 11345, 8080],

  "portsAttributes": {
    "6080": {
      "label": "Gazebo Desktop GUI",
      "onAutoForward": "notify"
    },
    "11345": {
      "label": "Gazebo Server",
      "onAutoForward": "silent"
    }
  },

  "remoteEnv": {
    "DISPLAY": ":1",
    "ROS_DOMAIN_ID": "0"
  },

  "runArgs": ["--privileged"]
}